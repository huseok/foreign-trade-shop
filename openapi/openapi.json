{
  "openapi": "3.0.3",
  "info": {
    "title": "Voyage API",
    "version": "1.0.0",
    "description": "Globuy 后端 voyage。响应体为 { code, message, data }；前端 mutator 解包 data。本文件可与运行中服务 `GET /v3/api-docs` 对照同步。"
  },
  "servers": [{ "url": "/", "description": "相对路径，由 axios baseURL 拼接" }],
  "tags": [
    { "name": "Auth", "description": "认证" },
    { "name": "Storefront", "description": "前台商城" },
    { "name": "Admin", "description": "后台管理（ADMIN）" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CaptchaResponse": {
        "type": "object",
        "required": ["captchaId", "imageBase64"],
        "properties": {
          "captchaId": { "type": "string", "description": "注册时随 captchaCode 一并提交" },
          "imageBase64": { "type": "string", "description": "data:image/png;base64,... 可直接作为 img src" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "name", "captchaId", "captchaCode"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 6 },
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "country": { "type": "string" },
          "captchaId": { "type": "string" },
          "captchaCode": { "type": "string", "description": "图片验证码，不区分大小写" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["accessToken", "refreshToken", "expiresIn"],
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "expiresIn": { "type": "integer", "format": "int64", "description": "Access token TTL (seconds)" }
        }
      },
      "RefreshTokenRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": { "refreshToken": { "type": "string" } }
      },
      "MeResponse": {
        "type": "object",
        "required": ["id", "email", "name", "role"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "MediaUploadView": {
        "type": "object",
        "required": ["thumbUrl", "fullUrl"],
        "properties": {
          "thumbUrl": { "type": "string", "description": "站点相对路径，如 /media/yyyy/MM/uuid_thumb.jpg" },
          "fullUrl": { "type": "string", "description": "完整图相对路径" }
        }
      },
      "ProductImageView": {
        "type": "object",
        "required": ["thumbUrl", "fullUrl"],
        "properties": {
          "thumbUrl": { "type": "string" },
          "fullUrl": { "type": "string" }
        }
      },
      "ProductImageRef": {
        "type": "object",
        "required": ["thumbUrl", "fullUrl"],
        "properties": {
          "thumbUrl": { "type": "string" },
          "fullUrl": { "type": "string" }
        }
      },
      "TagView": {
        "type": "object",
        "required": ["id", "code", "name", "sortNo", "isActive"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "sortNo": { "type": "integer" },
          "isActive": { "type": "boolean" }
        }
      },
      "StorefrontSettings": {
        "type": "object",
        "required": ["homePromoZoneTagCode"],
        "properties": {
          "homePromoZoneTagCode": {
            "type": "string",
            "description": "首页活动商品轮播绑定的标签编码（与标签管理 code 一致）"
          }
        }
      },
      "TagUpsertRequest": {
        "type": "object",
        "required": ["code", "name"],
        "properties": {
          "code": { "type": "string" },
          "name": { "type": "string" },
          "sortNo": { "type": "integer" },
          "isActive": { "type": "boolean" }
        }
      },
      "ProductOptionView": {
        "type": "object",
        "required": ["optionName", "optionValue", "sortNo"],
        "properties": {
          "optionName": { "type": "string" },
          "optionValue": { "type": "string" },
          "sortNo": { "type": "integer" }
        }
      },
      "ProductSkuView": {
        "type": "object",
        "required": ["id", "skuCode", "attrJson", "salePrice", "stockQty", "isActive"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "skuCode": { "type": "string" },
          "attrJson": { "type": "string" },
          "salePrice": { "type": "number" },
          "stockQty": { "type": "integer" },
          "weightKg": { "type": "number", "nullable": true },
          "isActive": { "type": "boolean" }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["oldPassword", "newPassword"],
        "properties": {
          "oldPassword": { "type": "string" },
          "newPassword": { "type": "string", "minLength": 6 }
        }
      },
      "ProductView": {
        "type": "object",
        "required": ["id", "title", "moq", "isActive"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "moq": { "type": "integer" },
          "description": { "type": "string", "nullable": true },
          "skuCode": { "type": "string", "nullable": true },
          "hsCode": { "type": "string", "nullable": true },
          "unit": { "type": "string", "nullable": true },
          "incoterm": { "type": "string", "nullable": true },
          "originCountry": { "type": "string", "nullable": true },
          "leadTimeDays": { "type": "integer", "nullable": true },
          "weightKg": { "type": "number", "nullable": true },
          "categoryId": { "type": "integer", "format": "int64", "nullable": true },
          "shippingTemplateId": { "type": "integer", "format": "int64", "nullable": true },
          "isActive": { "type": "boolean" },
          "options": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductOptionView" }
          },
          "skus": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductSkuView" }
          },
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductImageView" },
            "description": "前台列表优先展示首张 thumbUrl"
          },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TagView" },
            "description": "商品标签（多对多）"
          },
          "price": { "type": "number", "nullable": true },
          "listPrice": {
            "type": "number",
            "nullable": true,
            "description": "划线原价；非空且大于 price 时表示促销价"
          },
          "currency": { "type": "string", "nullable": true }
        }
      },
      "PagedProducts": {
        "type": "object",
        "required": ["items", "total", "page", "size"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductView" }
          },
          "total": { "type": "integer", "format": "int64" },
          "page": { "type": "integer" },
          "size": { "type": "integer" }
        }
      },
      "ProductAdminUpsertRequest": {
        "type": "object",
        "required": ["title", "price", "currency", "moq", "isActive"],
        "properties": {
          "title": { "type": "string" },
          "price": { "type": "number" },
          "listPrice": {
            "type": "number",
            "nullable": true,
            "description": "划线原价，须不低于 price；null 表示不设"
          },
          "currency": { "type": "string" },
          "moq": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" },
          "skuCode": { "type": "string" },
          "hsCode": { "type": "string" },
          "unit": { "type": "string" },
          "incoterm": { "type": "string" },
          "originCountry": { "type": "string" },
          "leadTimeDays": { "type": "integer" },
          "weightKg": { "type": "number" },
          "categoryId": { "type": "integer", "format": "int64" },
          "shippingTemplateId": { "type": "integer", "format": "int64" },
          "isActive": { "type": "boolean" },
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductImageRef" },
            "description": "null 不改图；[] 清空；非空覆盖排序"
          },
          "tagIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" },
            "description": "null 不改标签；[] 清空关联；非空覆盖"
          }
        }
      },
      "IdPayload": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "integer", "format": "int64" } }
      },
      "AddCartItemRequest": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": { "type": "integer", "format": "int64" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "UpdateCartItemRequest": {
        "type": "object",
        "required": ["quantity"],
        "properties": { "quantity": { "type": "integer", "minimum": 1 } }
      },
      "CartItemView": {
        "type": "object",
        "required": [
          "itemId",
          "productId",
          "title",
          "quantity",
          "unitPrice",
          "currency",
          "lineAmount"
        ],
        "properties": {
          "itemId": { "type": "integer", "format": "int64" },
          "productId": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "quantity": { "type": "integer" },
          "unitPrice": { "type": "string" },
          "currency": { "type": "string" },
          "lineAmount": { "type": "string" }
        }
      },
      "CartView": {
        "type": "object",
        "required": ["items", "totalAmount", "currency"],
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CartItemView" } },
          "totalAmount": { "type": "string" },
          "currency": { "type": "string" }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["receiverName", "receiverPhone", "country", "addressLine"],
        "properties": {
          "receiverName": { "type": "string" },
          "receiverPhone": { "type": "string" },
          "country": { "type": "string" },
          "addressLine": { "type": "string" },
          "postalCode": { "type": "string" },
          "receiverCompany": { "type": "string" },
          "taxNo": { "type": "string" },
          "incoterm": { "type": "string" },
          "shippingMethod": { "type": "string" }
        }
      },
      "OrderNoPayload": {
        "type": "object",
        "required": ["orderNo"],
        "properties": { "orderNo": { "type": "string" } }
      },
      "OrderItemView": {
        "type": "object",
        "required": ["productId", "titleSnapshot", "priceSnapshot", "quantity"],
        "properties": {
          "productId": { "type": "integer", "format": "int64" },
          "titleSnapshot": { "type": "string" },
          "priceSnapshot": { "type": "string" },
          "quantity": { "type": "integer" }
        }
      },
      "OrderView": {
        "type": "object",
        "required": [
          "orderNo",
          "status",
          "totalAmount",
          "currency",
          "receiverName",
          "receiverPhone",
          "country",
          "addressLine",
          "items"
        ],
        "properties": {
          "orderNo": { "type": "string" },
          "status": { "type": "string" },
          "totalAmount": { "type": "string" },
          "currency": { "type": "string" },
          "receiverName": { "type": "string" },
          "receiverPhone": { "type": "string" },
          "receiverCompany": { "type": "string", "nullable": true },
          "taxNo": { "type": "string", "nullable": true },
          "country": { "type": "string" },
          "addressLine": { "type": "string" },
          "postalCode": { "type": "string", "nullable": true },
          "incoterm": { "type": "string", "nullable": true },
          "shippingMethod": { "type": "string", "nullable": true },
          "logisticsCompany": { "type": "string", "nullable": true },
          "trackingNo": { "type": "string", "nullable": true },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItemView" } }
        }
      },
      "UpdateTrackingRequest": {
        "type": "object",
        "required": ["trackingNo"],
        "properties": {
          "trackingNo": { "type": "string" },
          "logisticsCompany": { "type": "string" }
        }
      },
      "UpdateOrderStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": { "status": { "type": "string" } }
      },
      "CreateAfterSaleRequest": {
        "type": "object",
        "required": ["orderNo", "content"],
        "properties": {
          "orderNo": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "AfterSaleView": {
        "type": "object",
        "required": ["id", "orderNo", "status", "content"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "orderNo": { "type": "string" },
          "status": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "UpdateAfterSaleStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": { "status": { "type": "string" } }
      }
    }
  },
  "paths": {
    "/api/v1/auth/captcha": {
      "get": {
        "tags": ["Auth"],
        "operationId": "authCaptcha",
        "summary": "注册用图形验证码",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CaptchaResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "operationId": "authRegister",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "registered",
            "content": { "application/json": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "operationId": "authLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "operationId": "authRefresh",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RefreshTokenRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "operationId": "authChangePassword",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangePasswordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["Auth"],
        "operationId": "authMe",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/MeResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/products": {
      "get": {
        "tags": ["Storefront"],
        "operationId": "productsList",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "页码，从 0 开始",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页条数，最大 100",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "country",
            "in": "query",
            "description": "按原产国筛选（精确，不区分大小写）",
            "schema": { "type": "string" }
          },
          {
            "name": "q",
            "in": "query",
            "description": "标题 / SKU / ID 搜索",
            "schema": { "type": "string" }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "按分类 ID 精确筛选（与类目导航联动）",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "tagId",
            "in": "query",
            "description": "按标签 ID 筛选（商品须关联该标签）",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "promo",
            "in": "query",
            "description": "true 时仅返回活动商品（已设划线价且高于售价）",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedProducts" }
              }
            }
          }
        }
      }
    },
    "/api/v1/storefront/settings": {
      "get": {
        "tags": ["Storefront"],
        "operationId": "storefrontSettingsGet",
        "summary": "前台只读配置（与 CMS 分离）",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StorefrontSettings" }
              }
            }
          }
        }
      }
    },
    "/api/v1/tags": {
      "get": {
        "tags": ["Storefront"],
        "operationId": "tagsListActive",
        "summary": "前台启用标签列表（目录筛选）",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TagView" }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/{id}": {
      "get": {
        "tags": ["Storefront"],
        "operationId": "productsGetById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductView" } }
            }
          }
        }
      }
    },
    "/api/v1/admin/products": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminProductsList",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "q",
            "in": "query",
            "description": "标题 / SKU / ID",
            "schema": { "type": "string" }
          },
          {
            "name": "active",
            "in": "query",
            "description": "true=仅上架，false=仅下架；不传=全部",
            "schema": { "type": "string", "enum": ["true", "false"] }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedProducts" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "operationId": "adminProductsCreate",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductAdminUpsertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/IdPayload" } }
            }
          }
        }
      }
    },
    "/api/v1/admin/products/{id}": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminProductsGetById",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductView" } }
            }
          }
        }
      },
      "put": {
        "tags": ["Admin"],
        "operationId": "adminProductsUpdate",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductAdminUpsertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/v1/admin/media/upload": {
      "post": {
        "tags": ["Admin"],
        "operationId": "adminMediaUpload",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
